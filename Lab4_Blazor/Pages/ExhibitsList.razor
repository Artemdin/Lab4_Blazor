@page "/"
@using Lab4_Blazor.Models
@using Lab4_Blazor.DTOs
@using Lab4_Blazor.Services
@inject ExhibitionService Service
@inject IJSRuntime js

<div class="main-container text-center">

    <h3 class="museum-header mb-4">🏛️ @Service.Hall.HallName</h3>

    <div class="alert alert-info shadow-sm mb-4">
        @Service.Hall.ToShortString()
    </div>

    <div class="list-group shadow-sm mb-4">
        @if (exhibits == null || !exhibits.Any())
        {
            <div class="list-group-item py-5">
                <p class="text-muted mb-0">Експонати відсутні. Натисніть "Додати", щоб розпочати.</p>
            </div>
        }
        else
        {
            @foreach (var exhibit in exhibits)
            {
                <button type="button" @onclick="() => SelectExhibit(exhibit)"
                        class="list-group-item list-group-item-action @(selectedExhibit?.Id == exhibit.Id ? "active-card" : "")">
                    <div class="row w-100 align-items-center">
                        <div class="col-4 text-start">
                            <b>@exhibit.Artwork?.Title</b>
                        </div>

                        <div class="col-4 text-center text-muted @(selectedExhibit?.Id == exhibit.Id ? "text-white" : "")">
                            <small>📍 @exhibit.Funds?.Address</small>
                        </div>

                        <div class="col-4 text-end">
                            <span class="badge rounded-pill bg-dark">@exhibit.Cost.ToString("N2") грн</span>
                        </div>
                    </div>
                </button>
            }
        }
    </div>

    <div class="d-flex justify-content-center gap-3">
        <button class="btn btn-success btn-lg px-5 shadow-sm" @onclick="Add">ДОДАТИ</button>
        <button class="btn btn-primary btn-lg px-5 shadow-sm" @onclick="Edit" disabled="@(selectedExhibit == null)">РЕДАГУВАТИ</button>
        <button class="btn btn-danger btn-lg px-4 shadow-sm" @onclick="Delete" disabled="@(selectedExhibit == null)">ВИДАЛИТИ</button>
    </div>

</div>

<ExhibitForm Show="showModal"
             Title="@modalTitle"
             Model="editingDto"
             OnSave="HandleSave"
             OnCancel="() => showModal = false" />

<style>
    body {
        background-color: #f0f2f5;
    }

    .main-container {
        max-width: 800px;
        margin: 40px auto;
        padding: 40px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .museum-header {
        color: #1a2a6c;
        font-weight: 800;
        text-transform: uppercase;
        border-bottom: 4px solid #f27121;
        display: inline-block;
        padding-bottom: 10px;
    }

    .list-group-item {
        border: 1px solid #eee !important;
        margin-bottom: 10px;
        border-radius: 12px !important;
        transition: 0.3s;
        text-align: left;
    }

        .list-group-item:hover {
            background-color: #fffaf0;
            transform: scale(1.01);
        }

    .active-card {
        background: linear-gradient(to right, #1a2a6c, #b21f1f) !important;
        color: white !important;
        border: none !important;
    }

        .active-card span {
            color: white !important;
        }

    .btn-lg {
        border-radius: 50px;
        padding: 12px 35px;
        font-weight: bold;
        text-transform: uppercase;
    }
</style>

@code {
    private List<Exhibit> exhibits = new();
    private Exhibit? selectedExhibit;
    private bool showModal = false;
    private string modalTitle = "";
    private ExhibitDTO editingDto = new();

    protected override async Task OnInitializedAsync()
    {
        await Service.LoadDataAsync();
        RefreshData();
    }

    private async Task Delete()
    {
        if (selectedExhibit == null) return;

        bool confirmed = await js.InvokeAsync<bool>("confirm", $"Видалити '{selectedExhibit.Artwork?.Title}'?");

        if (confirmed)
        {
            await Service.DeleteExhibit(selectedExhibit.Id);
            selectedExhibit = null; 
            RefreshData(); 
        }
    }
    private void RefreshData()
    {
        exhibits = Service.GetExhibits();
        StateHasChanged();
    }

    private void SelectExhibit(Exhibit exhibit) => selectedExhibit = exhibit;

    private void Add()
    {
        modalTitle = "Додати новий експонат";
        editingDto = new ExhibitDTO();
        showModal = true;
    }

    private void Edit()
    {
        if (selectedExhibit == null) return;
        modalTitle = "Редагувати експонат";
        editingDto = new ExhibitDTO
        {
            Artwork = new()
            {
                Title = selectedExhibit.Artwork?.Title ?? "",
                CreationYear = selectedExhibit.Artwork?.CreationYear ?? 0,
                Height = selectedExhibit.Artwork?.Height ?? 1,
                Width = selectedExhibit.Artwork?.Width ?? 1,
                Depth = selectedExhibit.Artwork?.Depth ?? 1
            },
            Funds = new() { Title = selectedExhibit.Funds?.Title ?? "" },
            Placement = selectedExhibit.Placement,
            Cost = selectedExhibit.Cost
        };
        showModal = true;
    }

    private async Task HandleSave(ExhibitDTO dto)
    {

        if (dto.Artwork.CreationYear > 2026 || dto.Artwork.CreationYear < 0)
        {
            await js.InvokeVoidAsync("alert", "Помилка: Рік створення не може бути в майбутньому або від'ємним!");
            return;
        }

        if (dto.Cost < 0)
        {
            await js.InvokeVoidAsync("alert", "Помилка: Ціна не може бути менше нуля!");
            return;
        }

        if (dto.Artwork.Height <= 0 || dto.Artwork.Width <= 0 || dto.Artwork.Depth <= 0)
        {
            await js.InvokeVoidAsync("alert", "Помилка: Розміри (висота, ширина, глибина) мають бути більшими за 0!");
            return;
        }


        var artwork = new Artwork
        {
            Title = dto.Artwork.Title,
            CreationYear = dto.Artwork.CreationYear,
            Height = dto.Artwork.Height,
            Width = dto.Artwork.Width,
            Depth = dto.Artwork.Depth
        };

        var funds = new Funds
        {
            Title = dto.Funds?.Title ?? "Фонд",
            Address = string.IsNullOrWhiteSpace(dto.FundAddress) ? "Не вказана" : dto.FundAddress
        };

        if (modalTitle.Contains("Додати"))
        {
            var newExhibit = new Exhibit(artwork, funds, dto.Placement, dto.Cost);
            newExhibit.Id = (exhibits != null && exhibits.Any() ? exhibits.Max(e => e.Id) : 0) + 1;
            await Service.SaveExhibit(newExhibit);
        }
        else if (selectedExhibit != null)
        {
            selectedExhibit.Artwork = artwork;
            selectedExhibit.Funds = funds;
            selectedExhibit.Placement = dto.Placement;
            selectedExhibit.Cost = dto.Cost;
            await Service.UpdateExhibit(selectedExhibit);
        }

        exhibits = Service.GetExhibits();
        showModal = false;
        selectedExhibit = null;
        StateHasChanged();
    }
}