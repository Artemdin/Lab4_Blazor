@page "/exhibits"
@using Lab4_Blazor.Models
@using Lab4_Blazor.DTOs
@inject ExhibitionService Service

<h3>Виставковий зал: @Service.Hall.HallName</h3>

<div class="alert alert-info">
    @Service.Hall.ToShortString()
</div>

<div class="list-group mb-3">
    @if (exhibits == null || !exhibits.Any())
    {
        <p class="text-muted">Експонати ще не додані або завантажуються...</p>
    }
    else
    {
        @foreach (var exhibit in exhibits)
        {
            <button type="button"
                    @onclick="() => SelectExhibit(exhibit)"
                    class="list-group-item list-group-item-action @(selectedExhibit == exhibit ? "active" : "")">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@exhibit.Artwork?.Title</h5>
                    <small>@exhibit.Cost.ToString("N2") грн</small>
                </div>
                <p class="mb-1">Фонд: @exhibit.Funds?.Title | Рік: @exhibit.Artwork?.CreationYear</p>
                <small>Розміщення: @exhibit.Placement</small>
            </button>
        }
    }
</div>

<div class="mt-3">
    <button class="btn btn-success" @onclick="Add">Додати</button>
    <button class="btn btn-primary" @onclick="Edit" disabled="@(selectedExhibit == null)">Редагувати</button>
</div>

<ExhibitForm Show="showModal"
             Title="@modalTitle"
             Model="editingDto"
             OnSave="HandleSave"
             OnCancel="() => showModal = false" />

@code {
    private List<Exhibit> exhibits = new();
    private Exhibit? selectedExhibit;
    private bool showModal = false;
    private string modalTitle = "";
    private ExhibitDTO editingDto = new();

    // Викликається автоматично при завантаженні сторінки
    protected override void OnInitialized()
    {
        RefreshData();
    }

    private void RefreshData()
    {
        // Отримуємо актуальні дані з SQLite
        exhibits = Service.GetExhibits();
    }

    private void SelectExhibit(Exhibit exhibit)
    {
        selectedExhibit = exhibit;
    }

    private void Add()
    {
        modalTitle = "Додати новий експонат";
        editingDto = new ExhibitDTO();
        showModal = true;
    }

    private void Edit()
    {
        if (selectedExhibit == null) return;

        modalTitle = "Редагувати експонат";

        editingDto = new ExhibitDTO
        {
            Artwork = new()
            {
                Title = selectedExhibit.Artwork.Title,
                CreationYear = selectedExhibit.Artwork.CreationYear,
                Height = selectedExhibit.Artwork.Height,
                Width = selectedExhibit.Artwork.Width,
                Depth = selectedExhibit.Artwork.Depth
            },
            Funds = new() { Title = selectedExhibit.Funds.Title },
            Placement = selectedExhibit.Placement,
            Cost = selectedExhibit.Cost
        };
        showModal = true;
    }

    private void HandleSave(ExhibitDTO dto)
    {
        // Створюємо об'єкти моделей на основі DTO
        var artwork = new Artwork
        {
            Title = dto.Artwork.Title,
            CreationYear = dto.Artwork.CreationYear,
            Height = dto.Artwork.Height,
            Width = dto.Artwork.Width,
            Depth = dto.Artwork.Depth
        };
        var funds = new Funds { Title = dto.Funds.Title };

        if (modalTitle.Contains("Додати"))
        {
            var newExhibit = new Exhibit(artwork, funds, dto.Placement, dto.Cost);
            Service.SaveExhibit(newExhibit);
        }
        else if (selectedExhibit != null)
        {
            // Оновлюємо існуючий об'єкт у базі
            selectedExhibit.Artwork = artwork;
            selectedExhibit.Funds = funds;
            selectedExhibit.Placement = dto.Placement;
            selectedExhibit.Cost = dto.Cost;

            // Викликаємо збереження змін у контексті БД
            Service.UpdateExhibit(selectedExhibit);
        }

        RefreshData(); // Оновлюємо список на екрані
        showModal = false;
        selectedExhibit = null;
    }
}