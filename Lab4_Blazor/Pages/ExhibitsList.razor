@page "/"
@using Lab4_Blazor.Models
@using Lab4_Blazor.DTOs
@using Lab4_Blazor.Services
@inject ExhibitionService Service
@inject IJSRuntime js

<div class="main-container text-center">

    <div class="hall-management mb-4 p-3 border rounded shadow-sm bg-light">
        <h5 class="mb-3">🏛️ Керування залами</h5>
        <div class="d-flex gap-2 justify-content-center">
            <select class="form-select w-50" @onchange="OnHallChanged">
                @foreach (var hall in Service.Halls)
                {
                    <option value="@hall.HallName" selected="@(Service.SelectedHall?.HallName == hall.HallName)">🏛️ @hall.HallName</option>
                }
            </select>
            <button class="btn btn-outline-primary" @onclick="AddNewHall">+ Новий зал</button>
        </div>
    </div>

    <h3 class="museum-header mb-4">🏛️ @Service.SelectedHall?.HallName</h3>

    <div class="alert alert-info shadow-sm mb-4">
        @Service.SelectedHall?.ToShortString()
    </div>

    @* --- СПИСОК ЕКСПОНАТІВ --- *@
    <div class="list-group shadow-sm mb-4">
        @if (Service.SelectedHall?.Exhibits == null || !Service.SelectedHall.Exhibits.Any())
        {
            <div class="list-group-item py-5">
                <p class="text-muted mb-0">У цьому залі порожньо. Натисніть "Додати".</p>
            </div>
        }
        else
        {
            @foreach (var exhibit in Service.SelectedHall.Exhibits)
            {
                <button type="button" @onclick="() => SelectExhibit(exhibit)"
                        class="list-group-item list-group-item-action @(selectedExhibit?.Id == exhibit.Id ? "active-card" : "")">
                    <div class="row w-100 align-items-center">
                        <div class="col-4 text-start">
                            <b>@exhibit.Artwork?.Title</b>
                        </div>
                        <div class="col-4 text-center text-muted @(selectedExhibit?.Id == exhibit.Id ? "text-white" : "")">
                            <small>📍 @exhibit.Funds?.Address</small>
                        </div>
                        <div class="col-4 text-end">
                            <span class="badge rounded-pill bg-dark">@exhibit.Cost.ToString("N2") грн</span>
                        </div>
                    </div>
                </button>
            }
        }
    </div>

    <div class="d-flex justify-content-center gap-3">
        <button class="btn btn-success btn-lg px-5 shadow-sm" @onclick="Add">ДОДАТИ</button>
        <button class="btn btn-primary btn-lg px-5 shadow-sm" @onclick="Edit" disabled="@(selectedExhibit == null)">РЕДАГУВАТИ</button>
        <button class="btn btn-danger btn-lg px-4 shadow-sm" @onclick="Delete" disabled="@(selectedExhibit == null)">ВИДАЛИТИ</button>
    </div>
</div>

<ExhibitForm Show="showModal" Title="@modalTitle" Model="editingDto" OnSave="HandleSave" OnCancel="() => showModal = false" />

@code {
    private Exhibit? selectedExhibit;
    private bool showModal = false;
    private string modalTitle = "";
    private ExhibitDTO editingDto = new();

    protected override async Task OnInitializedAsync()
    {
        await Service.LoadDataAsync();
        // Примусово кажемо сторінці оновитися після того, як дані прийшли з LocalStorage
        StateHasChanged();
    }

    private void OnHallChanged(ChangeEventArgs e)
    {
        var hallName = e.Value?.ToString();
        Service.SelectedHall = Service.Halls.FirstOrDefault(h => h.HallName == hallName);
        selectedExhibit = null;
        StateHasChanged();
    }

    private void Edit()
    {
        if (selectedExhibit == null) return;
        modalTitle = "Редагувати експонат";
        editingDto = new ExhibitDTO
        {
            Artwork = new()
            {
                Title = selectedExhibit.Artwork?.Title ?? "",
                CreationYear = selectedExhibit.Artwork?.CreationYear ?? 0,
                Height = selectedExhibit.Artwork?.Height ?? 1,
                Width = selectedExhibit.Artwork?.Width ?? 1,
                Depth = selectedExhibit.Artwork?.Depth ?? 1
            },
            Funds = new() { Title = selectedExhibit.Funds?.Title ?? "" },
            FundAddress = selectedExhibit.Funds?.Address ?? "",
            Placement = selectedExhibit.Placement,
            Cost = selectedExhibit.Cost
        };
        showModal = true;
    }

    private async Task AddNewHall()
    {
        string name = await js.InvokeAsync<string>("prompt", "Введіть назву нового залу:");
        if (!string.IsNullOrWhiteSpace(name))
        {
            if (Service.Halls.Any(h => h.HallName == name))
            {
                await js.InvokeVoidAsync("alert", "Зал з такою назвою вже існує!");
                return;
            }
            var newHall = new ExhibitionHall { HallName = name };
            Service.Halls.Add(newHall);
            Service.SelectedHall = newHall;
            await Service.SaveAll();
        }
    }

    private async Task HandleSave(ExhibitDTO dto)
    {
        // --- ПЕРЕВІРКИ ---
        if (string.IsNullOrWhiteSpace(dto.Artwork.Title) || string.IsNullOrWhiteSpace(dto.Funds.Title))
        {
            await js.InvokeVoidAsync("alert", "Помилка: Назва експонату та фонду не можуть бути порожніми!");
            return;
        }

        if (dto.Artwork.CreationYear > 2026 || dto.Artwork.CreationYear < 0 || dto.Cost < 0)
        {
            await js.InvokeVoidAsync("alert", "Помилка: Перевірте рік (не більше 2026) та ціну (не менше 0)!");
            return;
        }

        if (dto.Artwork.Height <= 0 || dto.Artwork.Width <= 0 || dto.Artwork.Depth <= 0)
        {
            await js.InvokeVoidAsync("alert", "Помилка: Розміри мають бути більшими за 0!");
            return;
        }

        // --- ЛОГІКА ЗБЕРЕЖЕННЯ ---
        var artwork = new Artwork
        {
            Title = dto.Artwork.Title,
            CreationYear = dto.Artwork.CreationYear,
            Height = dto.Artwork.Height,
            Width = dto.Artwork.Width,
            Depth = dto.Artwork.Depth
        };

        var funds = new Funds
        {
            Title = dto.Funds.Title,
            Address = string.IsNullOrWhiteSpace(dto.FundAddress) ? "Не вказана" : dto.FundAddress
        };

        if (modalTitle.Contains("Додати"))
        {
            var newExhibit = new Exhibit(artwork, funds, dto.Placement, dto.Cost);
            int maxId = Service.Halls.SelectMany(h => h.Exhibits).Any()
                        ? Service.Halls.SelectMany(h => h.Exhibits).Max(e => e.Id) : 0;
            newExhibit.Id = maxId + 1;
            Service.SelectedHall?.AddExhibit(newExhibit);
        }
        else if (selectedExhibit != null)
        {
            selectedExhibit.Artwork = artwork;
            selectedExhibit.Funds = funds;
            selectedExhibit.Placement = dto.Placement;
            selectedExhibit.Cost = dto.Cost;
        }

        await Service.SaveAll();
        showModal = false;
        selectedExhibit = null;
        StateHasChanged();
    }

    private void SelectExhibit(Exhibit exhibit) => selectedExhibit = exhibit;
    private void Add() { modalTitle = "Додати новий експонат"; editingDto = new ExhibitDTO(); showModal = true; }

    private async Task Delete()
    {
        if (selectedExhibit == null) return;
        if (await js.InvokeAsync<bool>("confirm", $"Видалити '{selectedExhibit.Artwork.Title}'?"))
        {
            Service.SelectedHall?.Exhibits.Remove(selectedExhibit);
            await Service.SaveAll();
            selectedExhibit = null;
            StateHasChanged();
        }
    }
}